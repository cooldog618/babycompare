generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  source      String   @default("demo")
  sourceId    String?
  title       String
  brand       String?
  category    String
  imageUrl    String?
  price       Int
  originalUrl String?
  rating      Float?
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
